<Page x:Class="GeneralElementsUI.UI.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:uControls="clr-namespace:GeneralElementsUI.UserControls"
      xmlns:pages="clr-namespace:GeneralElementsUI.UI.Pages"
      d:DataContext="{d:DesignInstance Type=pages:RegistrationPage, IsDesignTimeCreatable=True}"
      mc:Ignorable="d"
      Title="RegistrationPage" d:DesignHeight="450" d:DesignWidth="300">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <StackPanel>
        <TextBlock Text="Регистрация" Style="{StaticResource Head1}" HorizontalAlignment="Center"/>
        
        <ItemsControl ItemsSource="{Binding RegisterFields}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <uControls:UniversalTextBoxWithPlaceholder 
                        Placeholder="{Binding Name}" 
                        Text="{Binding Value, Mode=TwoWay}"
                        FieldMode="{Binding Type}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        <Button Content="Зарегистрироваться" Style="{StaticResource Button1}" Click="RegisterDone_OnClick" Margin="0 20 0 0"/>
    </StackPanel>
</Page>
