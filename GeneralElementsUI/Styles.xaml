<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:userControls="clr-namespace:GeneralElementsUI.UserControls">
                    
    <Style x:Key="PlaceholderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style x:Key="SmallText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
    </Style>
    
    <Style x:Key="RulePlaceholderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="MaxWidth" Value="200"/>
    </Style>
    
    <Style x:Key="PlaceholderWithTrimming" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="MaxWidth" Value="200"/>
    </Style>
    
    <Style x:Key="Word" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="5 0 5 0"/>
    </Style>
    
    <Style x:Key="Text" TargetType="TextBox">
        <Setter Property="Margin" Value="5 0 0 0"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style x:Key="ComboBox" TargetType="ComboBox">
        <Setter Property="Margin" Value="5 0 0 0"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style x:Key="DateTimePicker" TargetType="DatePicker">
        <Setter Property="Margin" Value="5 0 0 0"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style x:Key="Password" TargetType="PasswordBox">
        <Setter Property="Margin" Value="5 0 0 0"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style x:Key="Button1" TargetType="Button">
        <Setter Property="MaxWidth" Value="200"/>
        <Setter Property="MaxHeight" Value="30"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Margin" Value="0 5 0 5"/>
    </Style>
    
    <Style x:Key="Button2" TargetType="Button">
        <Setter Property="MaxWidth" Value="140"/>
        <Setter Property="MaxHeight" Value="30"/>
        <Setter Property="Margin" Value="0 5 0 5"/>
    </Style>
    
    <Style x:Key="SmallButton" TargetType="Button">
        <Setter Property="MaxWidth" Value="140"/>
        <Setter Property="MaxHeight" Value="30"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0 5 0 5"/>
    </Style>
    
    <Style x:Key="Head1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0 0 0 10"/>
    </Style>
    
    <Style x:Key="Head2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Margin" Value="0 0 0 10"/>
    </Style>
    
    <Style TargetType="userControls:TextBoxWithPlaceholder">
        <Setter Property="Margin" Value="0 10 0 10"/>
    </Style>
    
    <Style TargetType="userControls:ComboBoxWithPlaceholder">
        <Setter Property="Margin" Value="0 10 0 10"/>
    </Style>
    
    <Style TargetType="userControls:PasswordBoxWithPlaceholder">
        <Setter Property="Margin" Value="0 10 0 10"/>
    </Style>
    
    <Style TargetType="userControls:UniversalTextBoxWithPlaceholder">
        <Setter Property="Margin" Value="0 10 0 10"/>
    </Style>
</ResourceDictionary>