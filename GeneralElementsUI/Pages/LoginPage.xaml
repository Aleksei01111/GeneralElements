<Page x:Class="GeneralElementsUI.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:uControls="clr-namespace:GeneralElementsUI.UserControls"
      xmlns:local="clr-namespace:GeneralElementsUI.Pages"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=local:LoginPage, IsDesignTimeCreatable=True}"
      Title="LoginPage" d:DesignHeight="450" d:DesignWidth="300">
      <Page.Resources>
          <ResourceDictionary>
              <ResourceDictionary.MergedDictionaries>
                  <ResourceDictionary Source="../Styles.xaml"/>
              </ResourceDictionary.MergedDictionaries>
          </ResourceDictionary>
      </Page.Resources>
    <StackPanel>
        <TextBlock Text="Вход" Style="{StaticResource Head1}" HorizontalAlignment="Center"/>
        
        <ItemsControl ItemsSource="{Binding LoginFields}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <uControls:UniversalTextBoxWithPlaceholder 
                        Placeholder="{Binding Name}" 
                        Text="{Binding Value, Mode=TwoWay}"
                        FieldMode="{Binding Type}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        <Button Content="Войти" Style="{StaticResource Button1}" Click="Login_OnClick" Margin="0 20 0 0"/>
    </StackPanel>
</Page>
