<UserControl x:Class="GeneralElementsUI.UserControls.PasswordBoxWithPlaceholder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GeneralElementsUI.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="0.2*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Style="{StaticResource PlaceholderText}"
                   Text="{Binding Placeholder, 
            RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <PasswordBox Grid.Column="1" Style="{StaticResource Password}"
                     x:Name="PasswordPB" PasswordChanged="PasswordPB_OnPasswordChanged" />
        <TextBox Grid.Column="1" Visibility="Hidden" x:Name="PasswordText"
                 Text="{Binding Password, 
            RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource Text}"
                 TextChanged="PasswordText_OnTextChanged"/>
        
        <Image Grid.Column="2" 
               MouseLeftButtonDown="ShowPassword_OnMouseLeftButtonDown" MouseLeftButtonUp="HidePassword_OnMouseLeftButtonUp"
               Source="../Resources/Images/eye.png" Stretch="Uniform" Width="20"/>
    </Grid>
</UserControl>
