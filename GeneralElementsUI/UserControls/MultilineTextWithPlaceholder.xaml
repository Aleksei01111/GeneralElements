<UserControl x:Class="GeneralElementsUI.UserControls.MultilineTextWithPlaceholder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GeneralElementsUI.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="0.2*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.Column="0" Style="{StaticResource PlaceholderText}" VerticalAlignment="Top"
                   Text="{Binding Placeholder, RelativeSource={RelativeSource AncestorType={x:Type local:MultilineTextWithPlaceholder}}, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
        <TextBox Grid.Column="1" Style="{StaticResource Text}" Text="{Binding Text, 
                 RelativeSource={RelativeSource AncestorType={x:Type local:MultilineTextWithPlaceholder}}, 
                 UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" AcceptsTab="True"
                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch" TextWrapping="Wrap"
                 IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl},
                 Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
</UserControl>
